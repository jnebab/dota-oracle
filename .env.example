# ---------------------------------------------------------------------------
# Draft Oracle — environment variables
# Copy to .env (local) or set in the Vercel dashboard (prod). Never commit .env.
# The core draft advisor needs NONE of these; they power the backend (M3+).
# ---------------------------------------------------------------------------

# STRATZ GraphQL API — Bearer token, SERVER-SIDE ONLY. Never expose to client. (M4)
STRATZ_TOKEN=

# Optional — raise external rate limits (the app works without them). (M4)
OPENDOTA_KEY=
STEAM_KEY=

# Upstash Redis (REST) — cache + daily meta refresh. (M5)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret guarding the cron-triggered meta-refresh endpoint. (M5)
CRON_SECRET=

# Web build: API base URL. Empty = same-origin "/api" (Vercel default).
VITE_API_BASE=
